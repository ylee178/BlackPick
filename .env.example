# === Required ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Optional (features) ===
OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key
REMOVE_BG_API_KEY=your-remove-bg-key

# === Optional (infra) ===
NEXT_PUBLIC_SITE_URL=https://your-domain.com
CORS_ALLOW_ORIGIN=https://your-domain.com
SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# === Feature flags ===
# Set to "true" to reveal the Facebook login button in the UI. Default is
# hidden until Meta App Review is approved and the provider credentials
# are wired into Supabase. Requires a redeploy (flag is baked into the
# client bundle at build time).
NEXT_PUBLIC_ENABLE_FACEBOOK_LOGIN=false
