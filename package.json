{
  "name": "blackpick",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "ops:remote:verify": "node scripts/ops/verify-remote-schema.mjs",
    "ops:admin:bootstrap": "node scripts/ops/bootstrap-admin.mjs",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:fast": "vitest run --project unit --project component",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:chrome": "npx playwright test --project=chromium",
    "test:e2e:update-snapshots": "npx playwright test --update-snapshots",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "check:schema-drift": "node scripts/check-schema-drift.mjs",
    "check:usage": "node scripts/check-usage.mjs",
    "check:db": "npm run check:schema-drift",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "predeploy": "npm run check:i18n && npm run check:schema-drift && npm run test:fast && npm run build",
    "deploy": "npm run predeploy && vercel --prod && npm run smoke:prod"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/pretendard": "^5.2.5",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.1.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/nextjs-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-storybook": "^10.3.4",
    "jsdom": "^28.1.0",
    "playwright": "^1.59.1",
    "storybook": "^10.3.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
